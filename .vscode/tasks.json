{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: g++.exe 生成活动文件",
			"command": "C:/mingw64/bin/g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${workspaceFolder}/a.cpp",
				"${workspaceFolder}/queue.cpp",
				"${workspaceFolder}/lqueue.cpp",
				"${workspaceFolder}/erfen.cpp",
				"${workspaceFolder}/diguierfen.cpp",
				"${workspaceFolder}/sort.cpp",
				"${workspaceFolder}/priorityqueue.cpp",
				"${workspaceFolder}/hashtable.cpp",
				"-o",
				"${fileDirname}\\${fileBasenameNoExtension}.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "C:/mingw64/bin/g++.exe"
		}
	]
}